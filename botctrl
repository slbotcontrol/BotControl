      COMMAND="\"command\": \"getgroupmemberdata\", \"agent\": \"${CORRADE_BOT_ID}\", \"data\": \"OnlineStatus\""
      ;;
    curr*sim|position)
      COMMAND="\"command\": \"getnetworkdata\", \"data\": \"CurrentSim\""
      ;;
