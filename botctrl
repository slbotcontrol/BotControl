      if [ "${UUID}" ]; then
        cuuid="${UUID}"
      else
        if [ "${OBJ_NAME}" ]; then
          cuuid="${OBJ_NAME}"
        else
          echo "Corrade command ${cmd} requires object uuid or name"
          usage brief
        fi
      fi
      if [ "${cmd}" == "sit" ]; then
        COMMAND="\"command\": \"sit\", \"item\": \"${cuuid}\", \"range\": \"${CORRADE_RANGE}\", \"deanimate\": \"True\""
      else
        COMMAND="\"command\": \"touch\", \"item\": \"${cuuid}\", \"range\": \"${CORRADE_RANGE}\""
      fi
      ;;
