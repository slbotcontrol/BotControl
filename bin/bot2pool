#!/usr/bin/env bash
#
# bot2pool - send a bot to the zen garden pool
#
# Usage: bot2pool <bot name>

export PATH="/usr/local/bin:${PATH}"
[ -d /opt/homebrew/bin ] && {
  export PATH="/opt/homebrew/bin:${PATH}"
}

have_lb=$(type -p botctrl)
[ "${have_lb}" ] || {
  echo "ERROR: cannot locate botctrl in PATH"
  exit 1
}

have_jq=$(type -p jq)
[ "${have_jq}" ] || {
  echo "ERROR: cannot locate jq in PATH"
  exit 1
}

[ "$1" ] || {
  echo "Usage: bot2pool <bot name>"
  exit 1
}

bot="$*"

case "${bot}" in
  Anya*|anya*)
    # Check if Bot is online and if not, login
    botctrl -a status -n Anya | jq -r '.status' | grep -i online >/dev/null || {
      botctrl -a login -n Anya -l zen
      sleep 10
    }
    botctrl -a stand -n Anya >/dev/null 2>&1
    botctrl -a teleport -n Anya -l zen >/dev/null 2>&1
    sleep 5
    botctrl -a sit -n Anya -u zpool
    ;;
  Angel*|angel*)
    # Check if online
    [ -f /usr/local/BotControl/lib/online ] || {
      echo "ERROR: cannot locate /usr/local/BotControl/lib/online"
      exit 1
    }
    source /usr/local/BotControl/lib/online
    co_bot_online Angel || {
      echo "Angelus Portal does not appear to be online"
      exit 1
    }
    botctrl -a stand -c Angel >/dev/null 2>&1
    sleep 1
    botctrl -a teleport -c Angel -l zen >/dev/null 2>&1
    sleep 5
    botctrl -a sit -c Angel -u zpool
    ;;
  Easy*|easy*)
    # Check if online
    [ -f /usr/local/BotControl/lib/online ] || {
      echo "ERROR: cannot locate /usr/local/BotControl/lib/online"
      exit 1
    }
    source /usr/local/BotControl/lib/online
    co_bot_online Easy || {
      echo "Easy Islay does not appear to be online"
      exit 1
    }
    botctrl -a stand -c Easy >/dev/null 2>&1
    sleep 1
    botctrl -a teleport -c Easy -l zen >/dev/null 2>&1
    sleep 5
    botctrl -a sit -c Easy -u zpool
    ;;
esac
