#!/usr/bin/env bash

export PATH="/usr/local/bin:${PATH}"
[ -d /opt/homebrew/bin ] && {
  export PATH="/opt/homebrew/bin:${PATH}"
}

have_lb=$(type -p botctrl)
[ "${have_lb}" ] || {
  echo "ERROR: cannot locate botctrl in PATH"
  exit 1
}

have_jq=$(type -p jq)
[ "${have_jq}" ] || {
  echo "ERROR: cannot locate jq in PATH"
  exit 1
}

# Check if Bots are online and if not, login
needsleep=
for bot in Anya
do
  botctrl -a stand -n ${bot} >/dev/null 2>&1
  botctrl -a status -n ${bot} | jq -r '.status' | grep -i online >/dev/null || {
    botctrl -a login -n ${bot} -l beach
    needsleep=1
  }
done
[ "${needsleep}" ] && sleep 20

for bot in Anya
do
  botctrl -a stand -n ${bot} >/dev/null 2>&1
  sleep 1
  botctrl -a teleport -n ${bot} -l beach >/dev/null 2>&1
  sleep 5
  botctrl -a sit -n ${bot} -u barpole
done

for bot in Angel Easy
do
  # Check if online
  [ -f /usr/local/BotControl/lib/online ] || {
    echo "ERROR: cannot locate /usr/local/BotControl/lib/online"
    exit 1
  }
  source /usr/local/BotControl/lib/online
  co_bot_online ${bot} || {
    echo "${bot} does not appear to be online"
    continue
  }

  botctrl -a stand -c ${bot} >/dev/null 2>&1
  sleep 1
  botctrl -a teleport -c ${bot} -l beach >/dev/null 2>&1
  sleep 5
  botctrl -a sit -c ${bot} -u barpole
done
