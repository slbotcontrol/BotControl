#!/usr/bin/env bash

export PATH="/usr/local/bin:${PATH}"
[ -d /opt/homebrew/bin ] && {
  export PATH="/opt/homebrew/bin:${PATH}"
}

have_lb=$(type -p botctrl)
[ "${have_lb}" ] || {
  echo "ERROR: cannot locate botctrl in PATH"
  exit 1
}

# Run with -l argument to control Angelus Portal as a LifeBots Bot
# Default operation is to treat her like a Corrade bot
if [ "$1" == "-l" ]; then
  have_jq=$(type -p jq)
  [ "${have_jq}" ] || {
    echo "ERROR: cannot locate jq in PATH"
    exit 1
  }

  # Check if Bots are online and if not, login
  needsleep=
  botctrl -a stand -n Angel >/dev/null 2>&1
  botctrl -a status -n Angel | jq -r '.status' | grep -i online >/dev/null || {
    botctrl -a login -n Angel -l beach
    needsleep=1
  }
  [ "${needsleep}" ] && sleep 20

  # Send Angel to the beach pool float
  botctrl -a teleport -n Angel -l beach >/dev/null 2>&1
  sleep 5
  botctrl -a sit -n Angel -u bpool
else
  # Check if online
  [ -f /usr/local/BotControl/lib/online ] || {
    echo "ERROR: cannot locate /usr/local/BotControl/lib/online"
    exit 1
  }
  source /usr/local/BotControl/lib/online
  co_bot_online Angel || {
    echo "Angelus Portal does not appear to be online"
    exit 1
  }

  # Send Angel to the beach pool float
  botctrl -a stand -c Angel >/dev/null 2>&1
  botctrl -a teleport -c Angel -l beach >/dev/null 2>&1
  sleep 5
  botctrl -a wear_outfit -c Angel -O '** Legacy Basic Kai Nude **' >/dev/null 2>&1
  sleep 5
  botctrl -a sit -c Angel -u bpool
fi
