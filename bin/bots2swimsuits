#!/usr/bin/env bash

export PATH="/usr/local/bin:${PATH}"
[ -d /opt/homebrew/bin ] && {
  export PATH="/opt/homebrew/bin:${PATH}"
}

have_lb=$(type -p botctrl)
[ "${have_lb}" ] || {
  echo "ERROR: cannot locate botctrl in PATH"
  exit 1
}

BOTS="Angel Easy"
for bot in ${BOTS}
do
  # Check if online
  [ -f /usr/local/BotControl/lib/online ] || {
    echo "ERROR: cannot locate /usr/local/BotControl/lib/online"
    exit 1
  }
  source /usr/local/BotControl/lib/online
  co_bot_online ${bot} || {
    echo "${bot} does not appear to be online"
    continue
  }

  case ${bot} in
    Angel*|angel*|Angelus*)
      botctrl -a wear_outfit -c Angel -O '** Legacy Basic Kai Swim **' >/dev/null 2>&1
      ;;
    Easy*|easy*)
      botctrl -a wear_outfit -c Easy -O '** Legacy Basic Bikini Purple **' >/dev/null 2>&1
      ;;
    *)
      echo "Unsupported bot ${bot}"
      ;;
  esac
done
